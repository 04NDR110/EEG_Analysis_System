@model IEnumerable<EEG_Analysis_System.Models.AnalysisResult>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <a asp-action="History" class="btn btn-outline-info btn-sm">⬅ Zobacz archiwum</a>
        <h2 class="text-center flex-grow-1">Wizualizacja EEG i analiza WebNN</h2>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <canvas id="eegChart" style="width: 100%; height: 400px;"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Status II</h5>
                </div>
                <div class="card-body text-center">
                    <div id="aiStatus" class="mb-3">
                        <span class="badge bg-secondary p-2">Oczekiwanie...</span>
                    </div>
                    <hr />
                    <button id="startBtn" class="btn btn-success btn-lg w-100">Uruchom strumień</button>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Wynik analizy</h5>
                </div>
                <div class="card-body">
                    <p>Stan: <strong id="detectedState">-</strong></p>
                    <p>Pewność: <strong id="confidenceValue">0%</strong></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('eegChart').getContext('2d');

        let dataPoints = Array(50).fill(0);
        let labels = Array.from({length: 50}, (_, i) => i);

        const eegChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'EEG Signal (Channel 1)',
                    data: dataPoints,
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13, 110, 253, 0.1)',
                    borderWidth: 2,
                    tension: 0.3,
                    pointRadius: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                animation: false,
                scales: {
                    y: { min: -2.5, max: 2.5 },
                    x: { display: false }
                }
            }
        });

        let isAnalyzing = false;
        let updateInterval;

        // --- НОВА ФУНКЦІЯ ДЛЯ ВЗАЄМОДІЇ З БД ---
        async function saveToDatabase(state, confidence) {
            const payload = {
                ResultType: state,
                Confidence: parseFloat(confidence) / 100 // Перетворюємо відсотки (напр. 85) у формат 0.85
            };

            try {
                const response = await fetch('/Monitor/SaveResult', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(payload)
                });

                if (response.ok) {
                    console.log("✅ Wynik zapisany w bazie:", state);
                } else {
                    console.error("❌ Błąd zapisu сервером");
                }
            } catch (error) {
                console.error("❌ Błąd sieci:", error);
            }
        }

        function updateChart() {
            if (!isAnalyzing) return;

            const newValue = (Math.random() * 2 - 1) + Math.sin(Date.now() / 100) * 0.5;
            dataPoints.shift();
            dataPoints.push(newValue);
            eegChart.update();

            // Імітація аналізу та автоматичне збереження
            if (Math.random() > 0.98) {
                const states = ['Aktywność', 'Spokój'];
                const state = states[Math.floor(Math.random() * states.length)];
                const confidence = Math.floor(Math.random() * 20 + 80);

                // Оновлення UI
                document.getElementById('detectedState').textContent = state;
                document.getElementById('confidenceValue').textContent = confidence + '%';

                const badge = document.querySelector('#aiStatus .badge');
                badge.textContent = 'Analiza: ' + state;
                badge.className = state === 'Aktywność' ? 'badge bg-primary p-2' : 'badge bg-success p-2';

                // ВИКЛИК ЗБЕРЕЖЕННЯ В БД
                saveToDatabase(state, confidence);
            }
        }

        document.getElementById('startBtn').addEventListener('click', function() {
            if (!isAnalyzing) {
                isAnalyzing = true;
                this.textContent = 'Zatrzymaj strumień';
                this.classList.replace('btn-success', 'btn-danger');
                updateInterval = setInterval(updateChart, 50);
            } else {
                isAnalyzing = false;
                this.textContent = 'Uruchom strumień';
                this.classList.replace('btn-danger', 'btn-success');
                clearInterval(updateInterval);

                document.querySelector('#aiStatus .badge').textContent = 'Oczekiwanie...';
                document.querySelector('#aiStatus .badge').className = 'badge bg-secondary p-2';
            }
        });
    </script>
}