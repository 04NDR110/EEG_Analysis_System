@{
    ViewData["Title"] = "Strona główna";
}

<div class="container text-center mt-5">
    <h1 class="display-4">System analizy EEG</h1>
    <p class="lead text-muted">Wybierz sekcję, aby rozpocząć pracę</p>

    <div class="row mt-5 justify-content-center">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 bg-primary text-white">
                <div class="card-body d-flex flex-column justify-content-center">
                    <h3 class="card-title"><i class="fas fa-brain"></i> Monitorowanie</h3>
                    <p class="card-text">Analiza sygnałów EEG w czasie rzeczywistym z wykorzystaniem WebNN.</p>
                    <a asp-controller="Monitor" asp-action="Index" class="btn btn-light mt-3">Przejdź</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 bg-success text-white">
                <div class="card-body d-flex flex-column justify-content-center">
                    <h3 class="card-title"><i class="fas fa-archive"></i> Archiwum badań</h3>
                    <p class="card-text">Przeglądanie oraz eksport wyników historycznych.</p>
                    <a asp-controller="Monitor" asp-action="History" class="btn btn-light mt-3">Przejdź</a>
                </div>
            </div>
        </div>
    </div>
</div>